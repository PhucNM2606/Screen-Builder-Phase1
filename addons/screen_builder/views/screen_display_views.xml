<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="view_screen_display_tree" model="ir.ui.view">
        <field name="name">screen.builder.display.list</field>
        <field name="model">screen.builder.display</field>
        <field name="arch" type="xml">
            <list string="Screen Displays"
                  decoration-success="is_active"
                  decoration-muted="not is_active">

                <field name="code"/>
                <field name="name"/>
                <field name="model_id"/>
                <field name="view_type"/>
                <field name="public_url" widget="url"/>
                <field name="is_active" widget="boolean_toggle"/>

            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_screen_display_form" model="ir.ui.view">
        <field name="name">screen.builder.display.form</field>
        <field name="model">screen.builder.display</field>
        <field name="arch" type="xml">
            <form string="Screen Display">

                <header>
                    <field name="is_active" string="Active" widget="boolean_toggle"/>
                </header>

                <sheet>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Kitchen Monitor"/>
                        </h1>
                    </div>

                    <!-- Chỉ hiện sau khi lưu -->
                    <group invisible="not id">
                        <field name="code" readonly="1"/>
                    </group>

                    <group>

                        <group string="Display Configuration">

                            <field name="model_id"
                                   options="{'no_create': True, 'no_open': True}"/>

                            <field name="view_type"/>

                        </group>

                        <group string="Access">

                            <field name="token" readonly="1"/>

                            <field name="public_url"
                                   widget="url"
                                   readonly="1"/>

                        </group>

                    </group>

                    <separator string="Instructions"/>

                    <div class="alert alert-info" role="alert">
                        <strong>How to use</strong>
                        <br/>
                        1. Enter a display name.
                        <br/>
                        2. Select the source model.
                        <br/>
                        3. Choose the display type.
                        <br/>
                        4. Save the record.
                        <br/>
                        5. Copy the generated Public URL to display the screen without login.
                    </div>

                </sheet>

            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_screen_display" model="ir.actions.act_window">
        <field name="name">Screen Builder</field>
        <field name="res_model">screen.builder.display</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu -->
    <menuitem
        id="menu_screen_builder_root"
        name="Screen Builder"
        sequence="100"/>

    <menuitem
        id="menu_screen_builder_display"
        name="Displays"
        parent="menu_screen_builder_root"
        action="action_screen_display"/>

</odoo>